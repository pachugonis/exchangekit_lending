# App
APP_BASE_URL=https://exchangekit.cc
SECRET_KEY=change_me
ENVIRONMENT=development

# Database (локальный PostgreSQL)
DATABASE_URL=postgresql+asyncpg://exchangekit:exchangekit@localhost:5432/exchangekit
POSTGRES_USER=exchangekit
POSTGRES_PASSWORD=exchangekit
POSTGRES_DB=exchangekit
REDIS_URL=redis://localhost:6379/0

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://exchangekit.cc/payment/success
LICENSE_PRICE=29900.00

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@exchangekit.cc

# JWT
JWT_SECRET=change_me
JWT_EXPIRE_MINUTES=1440

# Frontend (в браузере запросы идут через nginx /api; это значение для SSR)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
